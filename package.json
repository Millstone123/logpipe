{
  "name": "logpipe",
  "version": "0.1.0",
  "description": "A small, composable CLI for tailing, filtering, and reshaping structured log streams.",
  "type": "module",
  "bin": {
    "logpipe": "src/cli.mjs"
  },
  "scripts": {
    "postinstall": "node --no-warnings src/setup.mjs",
    "start": "node --no-warnings src/demo.mjs data/events.db",
    "demo": "node --no-warnings src/demo.mjs data/events.db",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "logs",
    "cli",
    "ndjson",
    "logfmt"
  ],
  "license": "MIT"
}
